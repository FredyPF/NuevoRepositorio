Algoritmo ContarHasta3
	//Definir las variables
	Definir contador Como Entero
	//Iniciamos el contador en 1
	contador <- 1;
	
	//Crear condicion
	Mientras contador < 10 Hacer
		//Escribimos que debe Hacer
		Escribir "Numero actual: ", contador;
		//Incrementamos el contador siempre para evitar ciclos infinitos
		contador <- contador + 1;
	FinMientras
	
FinAlgoritmo
